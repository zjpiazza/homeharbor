{
	"name": "@homeharbor/api",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./routers/index": {
			"types": "./dist/routers/index.d.ts",
			"default": "./dist/routers/index.js"
		},
		"./inngest/client": {
			"types": "./dist/inngest/client.d.ts",
			"default": "./dist/inngest/client.js"
		},
		"./inngest/functions/index": {
			"types": "./dist/inngest/functions/index.d.ts",
			"default": "./dist/inngest/functions/index.js"
		}
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.750.0",
		"@aws-sdk/s3-request-presigner": "^3.750.0",
		"@hono/node-server": "^1.13.8",
		"@prisma/client": "^6.7.0",
		"@trpc/server": "^11.0.0",
		"better-auth": "^1.2.0",
		"dotenv": "^16.4.7",
		"hono": "^4.7.4",
		"inngest": "^3.35.1",
		"permitio": "^2.7.2",
		"superjson": "^2.2.2",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@faker-js/faker": "^10.4.0",
		"@types/node": "^22.13.10",
		"prisma": "^6.7.0",
		"tsx": "^4.19.3",
		"typescript": "^5.8.2"
	}
}
